# WalletConnect (Reown) Project ID
# Get your free project ID from https://cloud.reown.com/
# Required for WalletConnect integration
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Network Configuration
# Options: 'testnet' or 'mainnet'
NEXT_PUBLIC_HATHOR_NETWORK=testnet

# Development Mode
# Set to true to use mock wallet for development without connecting a real wallet
NEXT_PUBLIC_USE_MOCK_WALLET=false
