# Local Development Configuration
# Copy this file to .env.local to customize your local environment

# WalletConnect (Reown) Project ID
# Get your free project ID from https://cloud.reown.com/
# Required for WalletConnect integration
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Development Mock Wallet
# Set to true to use mock wallet for development without connecting a real wallet
# Useful for testing UI and contract interactions without wallet setup
NEXT_PUBLIC_USE_MOCK_WALLET=false

# Network Configuration
# Options: 'testnet' or 'mainnet'
# Note: You can switch networks in the UI at runtime
NEXT_PUBLIC_DEFAULT_NETWORK=testnet

# Hathor Node URLs (Advanced)
# Default values are provided, only override if using custom nodes
# NEXT_PUBLIC_HATHOR_NODE_URL_TESTNET=https://node-partners.testnet.hathor.network/v1a
# NEXT_PUBLIC_HATHOR_NODE_URL_MAINNET=https://node-partners.mainnet.hathor.network/v1a

# Your Nano Contract IDs
# Add your deployed contract IDs as a JSON array
# Example: ["0abc123def456...", "789ghi012jkl..."]
# Leave empty if you don't have contracts yet
NEXT_PUBLIC_CONTRACT_IDS=[]

# ===========================================
# Localnet (Hathor Forge) Configuration
# ===========================================

# Local Hathor Forge fullnode (used when NEXT_PUBLIC_DEFAULT_NETWORK=localnet)
# NEXT_PUBLIC_HATHOR_NODE_URL_LOCALNET=http://localhost:49180/v1a

# Bet blueprint ID — markets are nano contract instances of this blueprint
NEXT_PUBLIC_BET_BLUEPRINT_ID=
